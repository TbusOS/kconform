# Local editor / IDE state
.vscode/
.idea/
*.swp
*~

# Claude Code / agent workspace state (local-only, never shared)
.claude/
.cursor/

# Python / build byproducts (reserved for future Python helpers)
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Test scratch
/tests/_tmp/

# Deep-lint scratch (produced when kconform is invoked from inside the repo)
.kconform-tmp/

# design-review output (screenshots + critic prompts for docs/ pages)
/shots/

# OS cruft
.DS_Store
Thumbs.db
